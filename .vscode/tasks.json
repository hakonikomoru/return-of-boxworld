      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "bedrock-dev"
      }
    },
    {
      "label": "Bedrock: tail content log (ROBW only)",
      "type": "shell",
      "command": "node",
      "args": ["scripts/tail-bedrock-log.mjs", "--mirror", "--robw"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
